MINIO_ENDPOINT=localhost:9004
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=benchmarks
MINIO_USE_SSL=false
RABBITMQ_URL=amqp://guest:guest@localhost:5674/
